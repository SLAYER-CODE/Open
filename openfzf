        else
            printf "           ŌåÆ Agrega a tu shell config: ${BOLD}export PATH=\"%s:\$PATH\"${NC}\n" "$bindir"
        fi
    fi

    echo

    if ! $check_ok; then
        printf "  ${RED}[Ō£Ś]${NC} Algunos requisitos faltan. Revisa las marcas rojas arriba.\n"
        echo
        exit 1
    fi
    printf "  ${GREEN}[Ō£ō]${NC} Todo listo. Ejecuta ${BOLD}openfzf${NC} para comenzar.\n"
    echo
}

# Parse arguments
NO_VPN=false
AGENT_FLAGS=()
for arg in "$@"; do
    case "$arg" in
        --setup)              first_run_setup; exit 0 ;;
        --all)                AGENT_FLAGS=("ALL") ;;
        --plan)               AGENT_FLAGS+=("plan") ;;
        --build)              AGENT_FLAGS+=("build") ;;
        --explore|--explorer) AGENT_FLAGS+=("explore") ;;
        --general)            AGENT_FLAGS+=("general") ;;
        --no-vpn)             NO_VPN=true ;;
    esac
done

# Build SQL agent filter clauses
AGENT_WHERE=""   # for queries without existing WHERE
AGENT_AND=""     # for queries with existing WHERE
if [[ ${#AGENT_FLAGS[@]} -eq 0 ]]; then
    AGENT_WHERE="WHERE agent IN ('build', 'plan')"
    AGENT_AND="AND agent IN ('build', 'plan')"
elif [[ " ${AGENT_FLAGS[*]} " != *" ALL "* ]]; then
    quoted=$(printf "'%s'," "${AGENT_FLAGS[@]}")
    quoted="${quoted%,}"
    AGENT_WHERE="WHERE agent IN ($quoted)"
    AGENT_AND="AND agent IN ($quoted)"
fi

# === Init opened cache ===
mkdir -p "$CACHE_DIR"
sqlite3 "$OPENED_DB" "CREATE TABLE IF NOT EXISTS opened (id TEXT PRIMARY KEY, last_opened INTEGER);" 2>/dev/null || true

