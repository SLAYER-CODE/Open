# Adaptive column widths based on terminal size
setup_widths() {
    local cols
    cols=$(tput cols 2>/dev/null || echo "${COLUMNS:-80}")
    TITLE_W=30
    DIR_W=$((cols - TITLE_W - 7 - 10 - 3 - 4))
    if [[ $DIR_W -lt 10 ]]; then
        DIR_W=10
        TITLE_W=$((cols - DIR_W - 7 - 10 - 3 - 4))
        [[ $TITLE_W -lt 15 ]] && TITLE_W=15
    fi
    :
}
setup_widths

if [[ -n "$DEBUG" ]]; then
    dbg_count=$(sqlite3 "$DB" "SELECT COUNT(*) FROM session;" 2>&1) || dbg_count="ERROR"
    dbg_groups=$(sqlite3 "$DB" "SELECT COUNT(DISTINCT title) FROM session;" 2>&1) || dbg_groups="ERROR"
    echo "DEBUG: cols=$(tput cols) TITLE_W=$TITLE_W DIR_W=$DIR_W VPN=$VPN_ACTIVE sessions=$dbg_count groups=$dbg_groups" >&2
fi

abbrev_dir() {
    local dir="$1" max="$2" home="$HOME"
    [[ -z "$max" ]] && max=22
    if [[ "$dir" == "$home" ]]; then echo "~"; return; fi
    local rel
    if [[ "$dir" == "$home/"* ]]; then rel="${dir#$home/}"
    else rel="${dir#/}"; fi
    IFS='/' read -ra parts <<< "$rel"
    local n=${#parts[@]}
    [[ $max -lt 4 ]] && max=4
    if (( n == 1 )); then echo "${parts[0]:0:$max}"; return; fi
    local last="${parts[$((n-1))]}"
    local llen=${#last}
    # Full relative path fits
    local full
    printf -v full "/%s" "${parts[@]}"
    full="${full:1}"
    (( ${#full} <= max )) && { echo "$full"; return; }
    # Very tight ŌåÆ ../last (truncated if needed)
    (( max < llen + 4 )) && { echo "../${last:0:$((max-3))}"; return; }
    # Compress middle components to first letter, keep first and last full
    local first="${parts[0]}"
    local mid_count=$((n - 2))
    local compressed=$(( ${#first} + mid_count + llen + n - 1 ))
    if (( compressed <= max )); then
        local out="$first"
        for (( i=1; i<n-1; i++ )); do
            out+="/${parts[$i]:0:1}"
        done
        out+="/$last"
        echo "$out"
    else
        echo "../$last"
    fi
}

fmt_date() {
    local epoch_s="$1"
    date -d "@$epoch_s" '+%m/%d %H:%M' 2>/dev/null || date -r "$epoch_s" '+%m/%d %H:%M' 2>/dev/null || echo "?"
}

fmt_date_secs() {
    local epoch_s="$1"
    date -d "@$epoch_s" '+%m/%d %H:%M:%S' 2>/dev/null || date -r "$epoch_s" '+%m/%d %H:%M:%S' 2>/dev/null || echo "?"
}

# Color by recency: green <2d, yellow <7d, red >7d
date_color() {
    local epoch_s="$1" now
    now=$(date +%s)
    local days=$(( (now - epoch_s) / 86400 ))
    if [[ $days -lt 2 ]]; then
        echo "$GREEN"
    elif [[ $days -lt 7 ]]; then
        echo "$YELLOW"
    else
        echo "$RED"
    fi
}

# Strip "(fork #N)" suffix for canonical grouping
canonical_title() {
    local t="$1"
    if [[ "$t" =~ \ \(fork\ #[0-9]+\)$ ]]; then
        local suffix="${BASH_REMATCH[0]}"
        echo "${t:0: -${#suffix}}"
    else
        echo "$t"
    fi
}

# === Build level-1 entries (deduplicated by title) ===
build_l1() {
    mapfile -t lines < <(sqlite3 "$DB" "
ATTACH DATABASE '${OPENED_DB}' AS o;
SELECT MAX(session.id),
       CASE WHEN title REGEXP ' \(fork #[0-9]+\)$'
            THEN SUBSTR(title, 1, INSTR(title, ' (fork #') - 1)
            ELSE title
       END,
       COALESCE(NULLIF(MAX(agent),''),'general'),
       MAX(directory),
       MAX(time_updated),
       MAX(time_created),
       COUNT(*)
 FROM session LEFT JOIN o.opened ON session.id = o.opened.id
 ${AGENT_WHERE}
 GROUP BY 2
ORDER BY COALESCE(NULLIF(MAX(o.opened.last_opened), 0), MAX(time_updated)) DESC;
    " 2>/dev/null) || return 1

    [[ ${#lines[@]} -eq 0 ]] && return 1

    local entries=()
    local line id title agent dir epoch_up epoch_cr forks
    for line in "${lines[@]}"; do
        IFS='|' read -r id title agent dir epoch_up epoch_cr forks <<< "$line"
        [[ -z "$id" || -z "$title" ]] && continue
        local agent_col abbrev created short_id vpn_tag vpn_col fork_str
        agent_col=$(agent_color "$agent")
        abbrev=$(abbrev_dir "$dir" "$DIR_W")
        created=$(fmt_date "$((epoch_up/1000))")
        dcol=$(date_color "$((epoch_up/1000))")
        short_id="${id:0:14}"
        vpn_tag=" -"
        vpn_col="$DIM"
        [[ -n "$VPN_ACTIVE" ]] && { vpn_tag="VPN"; vpn_col="$GREEN"; }
        [[ ${#title} -gt $TITLE_W ]] && title="${title:0:$((TITLE_W-3))}..."
        if (( forks > 1 )); then
            fork_str="x${forks}"
        else
            fork_str=""
        fi
        entries+=("$(printf '%s\t%b%-*s%b %b%-*s%b %b%-*s%b %-*s %b%-*s%b %s' \
            "$id" \
            "$BOLD" "$TITLE_W" "$title" "$NC" \
            "$agent_col" "7" "$agent" "$NC" \
            "$dcol" "10" "$created" "$NC" \
            "$DIR_W" "$abbrev" \
            "$vpn_col" "3" "$vpn_tag" "$NC" \
            "$fork_str")")
    done

    # Prepend "New Session" entry
    local now_epoch now_date new_entry
    now_epoch=$(date +%s)
    now_date=$(fmt_date "$now_epoch")
    new_entry=$(printf '%s\t%b%-*s%b %b%-*s%b %b%-*s%b %-*s %b%-*s%b %s' \
        '__NEW_SESSION__' \
        "$BOLD$GREEN" "$TITLE_W" " + New Session" "$NC" \
        "$GREEN" "7" "create" "$NC" \
        "$GREEN" "10" "$now_date" "$NC" \
        "$DIR_W" "-" \
        "$DIM" "3" " -" "$NC" \
        "")
    entries=("$new_entry" "${entries[@]}")

    local header
    local ses_count=$(( ${#entries[@]} - 1 ))
    header=$(printf "${DIM}%d sesiones | + New Session (1era) | Enter=abrir | Ctrl+E=expandir forks${NC}" "$ses_count")

    if [[ ${#entries[@]} -eq 0 ]]; then
        echo "No sessions to display" >&2
        return 1
    fi
    local fzf_out
    fzf_out=$(printf '%s\n' "${entries[@]}" | fzf --ansi \
        --with-nth=2.. --delimiter=$'\t' \
        --header-first --header="$header" \
        --prompt="openfzf > " \
        --expect=ctrl-e,enter \
        --reverse --cycle) || true
    if [[ -n "$DEBUG" || -n "$DBGLOG" ]]; then
        local logline="build_l1: fzf_out='$(head -2 <<< "$fzf_out" | tr '\n' '|')'"
        if [[ -n "$DEBUG" ]]; then echo "$logline" >&2; fi
        if [[ -n "$DBGLOG" ]]; then echo "$logline" >> "$DBGLOG"; fi
    fi
    printf '%s\n' "$fzf_out"
}

# === Build level-2 entries (forks of a specific title) ===
gen_l2_entries() {
    local target_title="$1"
    local cols
    cols=$(tput cols 2>/dev/null || echo "${COLUMNS:-80}")
    local tw=25
    local aw=7
    local dw=$((cols - tw - aw - 15 - 4))
    if [[ $dw -lt 10 ]]; then
        dw=10
        tw=$((cols - dw - aw - 15 - 4))
        [[ $tw -lt 15 ]] && tw=15
    fi
    if [[ -n "$DEBUG" ]]; then echo "L2: cols=$cols tw=$tw dw=$dw" >&2; fi

    local escaped
    escaped=$(printf '%s' "$target_title" | sed "s/'/''/g; s/%/\\%/g; s/_/\\_/g")

    mapfile -t lines < <(sqlite3 "$DB" "
ATTACH DATABASE '${OPENED_DB}' AS o;
SELECT session.id, title, COALESCE(NULLIF(agent,''),'general'), directory, time_updated, time_created
 FROM session LEFT JOIN o.opened ON session.id = o.opened.id
 WHERE title LIKE '${escaped}%' ESCAPE '\'
 ${AGENT_AND}
 ORDER BY COALESCE(NULLIF(o.opened.last_opened, 0), time_updated) DESC;
    " 2>/dev/null) || return 1

    [[ ${#lines[@]} -eq 0 ]] && return 1

    local line id title agent dir epoch_up epoch_cr
    for line in "${lines[@]}"; do
        IFS='|' read -r id title agent dir epoch_up epoch_cr <<< "$line"
        [[ -z "$id" ]] && continue
        local agent_col abbrev created_full
        agent_col=$(agent_color "$agent")
        abbrev=$(abbrev_dir "$dir" "$dw")
        created_full=$(fmt_date_secs "$((epoch_up/1000))")
        dcol=$(date_color "$((epoch_up/1000))")
        [[ ${#title} -gt $tw ]] && title="${title:0:$((tw-3))}..."
        printf '%s\t%b%-*s%b %b%-*s%b %b%s%b %-*s\n' \
            "$id" \
            "$BOLD" "$tw" "$title" "$NC" \
            "$agent_col" "7" "$agent" "$NC" \
            "$dcol" "$created_full" "$NC" \
            "$dw" "$abbrev"
    done
}

build_l2() {
    local target_title="$1"
    local count
    count=$(sqlite3 "$DB" "SELECT COUNT(*) FROM session WHERE title LIKE '$(printf '%s' "$(canonical_title "$target_title")" | sed "s/'/''/g; s/%/\\%/g; s/_/\\_/g")%' ESCAPE '\' ${AGENT_AND};")
    local header
    header=$(printf "${DIM}%d forks de \"%s\" | Enter=abrir | Esc=volver${NC}" "$count" "$target_title")

    gen_l2_entries "$target_title" | fzf --ansi \
        --with-nth=2.. --delimiter=$'\t' \
        --header-first --header="$header" \
        --prompt="fork > " \
        --reverse --cycle || true
}

open_session() {
    local sid="$1" space="${2:-Local}"
    sqlite3 "$OPENED_DB" "INSERT OR REPLACE INTO opened VALUES ('$sid', strftime('%s','now') * 1000);"

    if [[ "$space" == "Local" ]]; then
        local cmd="opencode --session \"$sid\""
        if command -v kitty &>/dev/null; then
            kitty @ launch --type=os-window --title "opencode:${sid:0:12}" --hold \
                bash -c "$cmd" 2>/dev/null || \
            kitty --hold bash -c "$cmd" &>/dev/null & disown
        else
            echo "Session ID: $sid"
            echo "Run: opencode --session $sid"
        fi
    else
        if command -v kitty &>/dev/null; then
            kitty --hold bash -c "sudo ip netns exec \"$space\" runuser -u \"$ORIG_USER\" -- opencode --session \"$sid\"" &>/dev/null & disown
        else
            echo "sudo ip netns exec $space runuser -u $ORIG_USER -- opencode --session $sid"
        fi
    fi
}

new_session() {
    local space="${1:-Local}"

    if [[ "$space" == "Local" ]]; then
        if command -v kitty &>/dev/null; then
            kitty @ launch --type=os-window --title "opencode:new" --hold \
                bash -c "opencode" 2>/dev/null || \
            kitty --hold bash -c "opencode" &>/dev/null & disown
        else
            echo "Run: opencode"
        fi
    else
        if command -v kitty &>/dev/null; then
            kitty --hold bash -c "sudo ip netns exec \"$space\" runuser -u \"$ORIG_USER\" -- opencode" &>/dev/null & disown
        else
            echo "sudo ip netns exec $space runuser -u $ORIG_USER -- opencode"
        fi
    fi
}

# === Entry point ===
if [[ -n "$SHOW_ALL_FORKS" ]]; then
    setup_widths
    fmt_tw=$TITLE_W
    fmt_dw=$DIR_W

    # Skip dedup, show all sessions (for EXPANDED view by default)
    mapfile -t lines < <(sqlite3 "$DB" "
ATTACH DATABASE '${OPENED_DB}' AS o;
SELECT session.id, title, COALESCE(NULLIF(agent,''),'general'), directory, time_updated, time_created
FROM session LEFT JOIN o.opened ON session.id = o.opened.id
${AGENT_WHERE}
ORDER BY COALESCE(NULLIF(o.opened.last_opened, 0), time_updated) DESC;
    " 2>/dev/null) || { echo "Error: DB error" >&2; exit 1; }
    [[ ${#lines[@]} -eq 0 ]] && { echo "No sessions."; exit 1; }

    entries=()
    for line in "${lines[@]}"; do
        IFS='|' read -r id title agent dir epoch_up epoch_cr <<< "$line"
        [[ -z "$id" || -z "$title" ]] && continue
        agent_col=$(agent_color "$agent")
        abbrev=$(abbrev_dir "$dir" "$fmt_dw")
        created=$(fmt_date "$((epoch_up/1000))")
        dcol=$(date_color "$((epoch_up/1000))")
        short_id="${id:0:14}"
        vpn_tag=" -"; vpn_col="$DIM"
        [[ -n "$VPN_ACTIVE" ]] && { vpn_tag="VPN"; vpn_col="$GREEN"; }
        [[ ${#title} -gt $fmt_tw ]] && title="${title:0:$((fmt_tw-3))}..."
        entries+=("$(printf '%s\t%b%-*s%b %b%-*s%b %b%-*s%b %-*s %b%-*s%b' \
            "$id" \
            "$BOLD" "$fmt_tw" "$title" "$NC" \
            "$agent_col" "7" "$agent" "$NC" \
            "$dcol" "10" "$created" "$NC" \
            "$fmt_dw" "$abbrev" \
            "$vpn_col" "3" "$vpn_tag" "$NC")")
    done

    header=$(printf "${DIM}%d sesiones | Enter=abrir${NC}" "${#entries[@]}")

    selected=$(printf '%s\n' "${entries[@]}" | fzf --ansi \
        --with-nth=2.. --delimiter=$'\t' \
        --header-first --header="$header" \
        --prompt="openfzf > " \
        --reverse --cycle) || true
    [[ -z "$selected" ]] && exit 0
    if [[ "$NO_VPN" == "true" ]]; then
        space="Local"
    else
        space=$(select_space) || true
        [[ -z "$space" ]] && exit 0
    fi
    open_session "$(cut -f1 <<< "$selected")" "$space"
    exit 0
fi

# === Normal flow: Level 1 ŌåÆ Level 2 (loop) ===
log() { local m="$1"; if [[ -n "$DEBUG" ]]; then echo "$m" >&2; fi; if [[ -n "$DBGLOG" ]]; then echo "$m" >> "$DBGLOG"; fi; }

while true; do
    l1_out=$(build_l1) || true
    [[ -z "$l1_out" ]] && exit 0

    l1_key=$(head -1 <<< "$l1_out")
    l1_sel=$(tail -n +2 <<< "$l1_out" | head -1)
    [[ -z "$l1_sel" ]] && exit 0

    l1_id=$(cut -f1 <<< "$l1_sel")

    if [[ "$l1_id" == "__NEW_SESSION__" ]]; then
        if [[ "$NO_VPN" == "true" ]]; then
            space="Local"
        else
            space=$(select_space) || true
            [[ -z "$space" ]] && continue
        fi
        new_session "$space"
        continue
    fi

    # Look up title and fork count
    escaped_id=$(printf '%s' "$l1_id" | sed "s/'/''/g")
    raw_title=$(sqlite3 "$DB" "SELECT title FROM session WHERE id = '$escaped_id' LIMIT 1;" || echo "")

    fork_count=0; canonical=""
    if [[ -n "$raw_title" ]]; then
        canonical=$(canonical_title "$raw_title")
        ec=$(printf '%s' "$canonical" | sed "s/'/''/g; s/%/\\%/g; s/_/\\_/g")
        fork_count=$(sqlite3 "$DB" "SELECT COUNT(*) FROM session WHERE title LIKE '${ec}%' ESCAPE '\';")
    fi

    log "l1_key='$l1_key' l1_id='$l1_id' raw_title='$raw_title' canonical='$canonical' fork_count='$fork_count'"

    if [[ -z "$canonical" ]] || (( fork_count <= 1 )); then
        log "no forks, opening session directly"
        if [[ "$NO_VPN" == "true" ]]; then
            space="Local"
        else
            space=$(select_space) || true
            [[ -z "$space" ]] && continue
        fi
        open_session "$l1_id" "$space"
        continue
    fi

    log "showing level 2 for '$canonical'"
    l2_out=$(build_l2 "$canonical") || true
    log "l2_out='${l2_out:0:60}...'"
    [[ -z "$l2_out" ]] && continue  # Escape ŌåÆ back to level 1
    if [[ "$NO_VPN" == "true" ]]; then
        space="Local"
    else
        space=$(select_space) || true
        [[ -z "$space" ]] && continue
    fi
    open_session "$(cut -f1 <<< "$l2_out")" "$space"
    continue
done
