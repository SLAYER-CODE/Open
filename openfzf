    if (( BASH_VERSINFO[0] >= 4 )); then
        printf "  ${GREEN}[Ō£ō]${NC} %-12s bash %d\n" "bash" "$BASH_VERSINFO[0]"
    else
        printf "  ${RED}[Ō£Ś]${NC} %-12s bash 4+ required (found %d)\n" "bash" "$BASH_VERSINFO[0]"
