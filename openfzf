    if [[ -d "${HOME}/.config/vpns" ]]; then
        printf "  ${GREEN}[Ō£ō]${NC} %-12s %s\n" "vpns config" "${HOME}/.config/vpns"
    else
        printf "  ${YELLOW}[!]${NC} %-12s %s (not found ŌĆö install vpns for VPN support)\n" "vpns config" "${HOME}/.config/vpns"
    fi

    echo

    # PATH check
    printf "  ${BOLD}PATH:${NC}\n"
    local bindir
    bindir=$(dirname "$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")")
    if command -v openfzf &>/dev/null && [[ "$(command -v openfzf)" == "$bindir/openfzf" ]]; then
        printf "  ${GREEN}[Ō£ō]${NC} %-12s %s\n" "openfzf" "$(command -v openfzf)"
    else
