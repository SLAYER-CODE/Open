#!/usr/bin/env bash
set -euo pipefail

error_handler() {
    local rc=$?
    if [[ $rc -ne 0 ]]; then
        echo "openfzf: error (exit ${rc})" >&2
    fi
}
trap error_handler EXIT

DB="${HOME}/.local/share/opencode/opencode.db"
CACHE_DIR="${HOME}/.cache/openfzf"
OPENED_DB="${CACHE_DIR}/opened.db"
SPACES_FILE="${HOME}/.config/vpns/spaces"
DNS_SERVER="1.1.1.1"
OPENCODE_PORT=4096
VPN_TIMEOUT="${VPN_TIMEOUT:-30}"
SUBNET_COUNTER="${HOME}/.config/vpns/subnet_counter"
SHOW_ALL_FORKS="${OPENFZF_ALL:-}"
DEBUG="${OPENFZF_DEBUG:-}"
DBGLOG="${OPENFZF_LOG:-}"

if [[ -t 1 ]]; then
    RED=$'\033[31m'; GREEN=$'\033[32m'; YELLOW=$'\033[33m'
    BLUE=$'\033[34m'; MAGENTA=$'\033[35m'; CYAN=$'\033[36m'
    BOLD=$'\033[1m'; DIM=$'\033[2m'; NC=$'\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; BLUE=''; MAGENTA=''; CYAN=''; BOLD=''; DIM=''; NC=''
fi

agent_color() {
    case "$1" in plan) echo "$BLUE" ;; build) echo "$GREEN" ;; create) echo "$GREEN" ;; explore) echo "$YELLOW" ;; general|"") echo "$CYAN" ;; *) echo "$NC"  ;; esac
}

CONFIG_DIR="${HOME}/.config/vpns"

vpn_directories() {
    local config_file="${CONFIG_DIR}/config" dirs=()
    if [[ -f "$config_file" ]]; then
        while IFS= read -r line; do
            line="${line#"${line%%[![:space:]]*}"}"
            line="${line%"${line##*[![:space:]]}"}"
            [[ -z "$line" || "$line" == \#* ]] && continue
            line="${line/#\~/$HOME}"
            line="${line/#\$HOME/$HOME}"
            dirs+=("$line")
        done < "$config_file"
    fi
    [[ ${#dirs[@]} -eq 0 ]] && dirs=("${HOME}/Downloads/VPNS")
    printf '%s\n' "${dirs[@]}"
}

find_config() {
    local config_name="$1" dir
    while IFS= read -r dir; do
        local result
        result=$(find "$dir" -name "$config_name" -type f -print -quit 2>/dev/null) || true
        [[ -n "$result" ]] && { echo "$result"; return 0; }
    done < <(vpn_directories)
    return 1
}

VPN_ACTIVE=""
detect_active_vpn() {
    if [[ -f "$SPACES_FILE" ]]; then
        local name
        while IFS='|' read -r name _; do
            if sudo -n ip netns list 2>/dev/null | grep -qw "$name"; then
                if sudo -n ip netns exec "$name" ip addr show tun0 &>/dev/null 2>/dev/null; then
                    echo "$name"
                    return
                fi
            fi
        done < "$SPACES_FILE"
    fi
}
VPN_ACTIVE=$(detect_active_vpn)

# Detect original user (for sudo namespace execution)
ORIG_USER="${SUDO_USER:-$USER}"

# === Space selector (VPN namespaces) ===
select_space() {
    while true; do
        local entries=() spaces=()
        declare -A times
        if [[ -f "$SPACES_FILE" ]]; then
            local name cfg ip ts subnet
            while IFS='|' read -r name cfg ip ts subnet; do
                [[ -n "$name" ]] && spaces+=("$name") && times["$name"]="$ts"
            done < "$SPACES_FILE"
        fi

        entries+=("Local|  Local")

        local s running
        for s in "${spaces[@]}"; do
            local t="${times[$s]:-}"
            local time_str=""
            [[ -n "$t" ]] && time_str="  ${BLUE}($(relative_time "$t"))${NC}"
            if sudo -n ip netns list 2>/dev/null | grep -qw "$s"; then
                running=true
            else
                running=false
            fi
            if [[ "$running" == "true" ]]; then
                if sudo -n ip netns exec "$s" ip addr show tun0 &>/dev/null 2>/dev/null; then
                    entries+=("$s|  ŌŚÅ ${s}${time_str}")
                else
                    entries+=("$s|  ŌŚŗ ${s}${time_str}")
                fi
            else
                entries+=("$s|${DIM}  ŌŚŗ ${s}${time_str}${NC}")
            fi
        done

        entries+=("__NEW_VPN__|  Crear New VPN")

        local selected
        selected=$(printf '%s\n' "${entries[@]}" | fzf --ansi --delimiter='|' --with-nth=2.. \
            --header="${DIM}Seleccionar espacio VPN | Enter=aceptar | Esc=cancelar${NC}" \
            --reverse --cycle) || { echo ""; return 1; }
        [[ -z "$selected" ]] && { echo ""; return 1; }

        local space
        space=$(cut -d'|' -f1 <<< "$selected")

        [[ "$selected" == *"${DIM}"* ]] && continue

        if [[ "$space" == "__NEW_VPN__" ]]; then
            create_new_vpn || true
            continue
        fi

        echo "$space"
        return
    done
}

# === VPN creation helpers (ported from vpns) ===
ns_pid_file() { echo "/tmp/openvpn-$1.pid"; }
ns_log_file() { echo "/tmp/openvpn-$1.log"; }
ns_socat_host_pid() { echo "/tmp/socat-host-$1.pid"; }
ns_socat_ns_pid() { echo "/tmp/socat-ns-$1.pid"; }
ns_opencode_serve_pid() { echo "/tmp/opencode-serve-$1.pid"; }
ns_socat_opencode_pid() { echo "/tmp/socat-opencode-$1.pid"; }

get_iface() {
    ip route get 8.8.8.8 2>/dev/null | awk '{print $5; exit}' || \
    ip route 2>/dev/null | awk '/default/ {print $5; exit}' || \
    echo "eth0"
}

ns_is_running() { sudo -n ip netns list 2>/dev/null | grep -qw "$1"; }

ns_vpn_connected() { sudo -n ip netns exec "$1" ip addr show tun0 &>/dev/null 2>/dev/null; }

has_socat() { command -v socat &>/dev/null; }

relative_time() {
    local ts="$1"
    local ts_epoch now_epoch diff
    ts_epoch=$(date -u -d "$ts" +%s 2>/dev/null) || { echo ""; return; }
    now_epoch=$(date -u +%s)
    diff=$((now_epoch - ts_epoch))
    if (( diff < 60 )); then
        echo "hace ${diff}s"
    elif (( diff < 3600 )); then
        echo "hace $((diff / 60))min"
    elif (( diff < 86400 )); then
        echo "hace $((diff / 3600))h"
    else
        echo "hace $((diff / 86400))d"
    fi
}

ns_veth_host() { echo "vh-$(echo "$1" | md5sum | head -c6)"; }
ns_veth_ns()   { echo "vn-$(echo "$1" | md5sum | head -c6)"; }

get_space_subnet() {
    grep "^$1|" "$SPACES_FILE" 2>/dev/null | cut -d'|' -f5 || echo ""
}

ns_alloc_subnet() {
    local ns="$1" idx
    idx=$(get_space_subnet "$ns")
    [[ -n "$idx" ]] && { echo "$idx"; return; }
    local next=1
    if [[ -f "$SUBNET_COUNTER" ]]; then
        next=$(< "$SUBNET_COUNTER")
    else
        local max_idx
        max_idx=$(cut -d'|' -f5 "$SPACES_FILE" 2>/dev/null | sort -n | tail -1)
        [[ -n "$max_idx" ]] && next="$max_idx"
    fi
    next=$((next + 1))
    echo "$next" > "$SUBNET_COUNTER"
    echo "$next"
}

ns_host_ip()   { local i; i=$(ns_alloc_subnet "$1"); echo "10.200.$i.1/24"; }
ns_ns_ip()     { local i; i=$(ns_alloc_subnet "$1"); echo "10.200.$i.2/24"; }
ns_subnet_cidr(){ local i; i=$(ns_alloc_subnet "$1"); echo "10.200.$i.0/24"; }
ns_gateway()   { local i; i=$(ns_alloc_subnet "$1"); echo "10.200.$i.1"; }

ns_cleanup() {
    local ns="$1" pid f
    echo "[+] Deteniendo OpenVPN..." >&2
    pid=$(ns_pid_file "$ns")
    if [[ -f "$pid" ]]; then
        sudo kill "$(cat "$pid")" 2>/dev/null || true
        sudo rm -f "$pid"
    fi
    echo "[+] Deteniendo ADB forwarders..." >&2
    for f in "$(ns_socat_host_pid "$ns")" "$(ns_socat_ns_pid "$ns")"; do
        if [[ -f "$f" ]]; then
            sudo kill "$(cat "$f")" 2>/dev/null || true
            sudo rm -f "$f"
        fi
    done
    echo "[+] Deteniendo OpenCode serve..." >&2
    f=$(ns_opencode_serve_pid "$ns")
    if [[ -f "$f" ]]; then
        sudo kill "$(cat "$f")" 2>/dev/null || true
        sudo rm -f "$f"
    fi
    echo "[+] Deteniendo forwarder OpenCode..." >&2
    f=$(ns_socat_opencode_pid "$ns")
    if [[ -f "$f" ]]; then
        sudo kill "$(cat "$f")" 2>/dev/null || true
        sudo rm -f "$f"
    fi
    echo "[+] Eliminando namespace..." >&2
    sudo ip netns delete "$ns" 2>/dev/null || true
    echo "[+] Eliminando veth..." >&2
    sudo ip link delete "$(ns_veth_host "$ns")" 2>/dev/null || true
    local subnet_idx inet_iface
    subnet_idx=$(get_space_subnet "$ns")
    if [[ -n "$subnet_idx" ]]; then
        inet_iface=$(get_iface)
        echo "[+] Eliminando regla NAT..." >&2
        sudo iptables -t nat -D POSTROUTING -s "10.200.$subnet_idx.0/24" -o "$inet_iface" -j MASQUERADE 2>/dev/null || true
    fi
}

auto_name() {
    local config_name="$1" base final suffix=1
    base=$(basename "$config_name" .ovpn | LC_ALL=C sed 's/[^_a-zA-Z0-9-]/_/g' | sed 's/__*/_/g' | sed 's/^_//;s/_$//')
    [[ -z "$base" ]] && base="space"
    final="$base"
    while grep -q "^$final|" "$SPACES_FILE" 2>/dev/null; do
        final="${base}-${suffix}"
        ((suffix++))
    done
    echo "$final"
}

save_space() {
    local ns="$1" config="$2" ip="$3" subnet="$4" ts
    ts=$(date -u +"%Y-%m-%dT%H:%M:%S")
    grep -v "^$ns|" "$SPACES_FILE" 2>/dev/null > "${SPACES_FILE}.tmp" || true
    echo "$ns|$config|$ip|$ts|$subnet" >> "${SPACES_FILE}.tmp"
    mv "${SPACES_FILE}.tmp" "$SPACES_FILE"
}

select_ovpn() {
    declare -A map
    local ns cfg ip ts subnet
    while IFS='|' read -r ns cfg ip ts subnet; do
        map["$cfg"]="$ns|$ip|$ts"
    done < "$SPACES_FILE" || true

    local lines=() dir all_ovpn=()

    while IFS= read -r dir; do
        while IFS= read -r -d '' f; do
            all_ovpn+=("$f")
        done < <(find "$dir" -name '*.ovpn' -type f -print0 2>/dev/null || true) || true
    done < <(vpn_directories)

    short_label() {
        local fp="$1" d
        while IFS= read -r d; do
            if [[ "$fp" == "$d"* ]]; then
                local rel="${fp#$d/}"
                echo "$(basename "$d")/$rel"
                return
            fi
        done < <(vpn_directories)
        basename "$fp"
    }

    local f
    for f in "${all_ovpn[@]}"; do
        local b
        b=$(basename "$f")
        [[ -z "${map[$b]:-}" ]] && lines+=("$(short_label "$f")")
    done

    while IFS='|' read -r ns cfg ip ts subnet; do
        local cfg_path
        cfg_path=$(find_config "$cfg") || continue
        local label txt col
        label=$(short_label "$cfg_path")
        if ns_is_running "$ns" 2>/dev/null && ns_vpn_connected "$ns" 2>/dev/null; then
            col="$GREEN"
            [[ -z "$ip" || "$ip" == "offline" ]] && txt="Connected" || txt="$ip"
        else
            col="$RED"
            txt="offline"
        fi
        lines+=("${label} ŌåÆ ${col}ŌŚÅ ${txt}${NC}  ${BLUE}($(relative_time "$ts"))${NC}")
    done < "$SPACES_FILE" || true

    if [[ ${#lines[@]} -eq 0 ]]; then
        echo "No hay archivos .ovpn en los directorios configurados" >&2
        echo "(revisa ~/.config/vpns/config)" >&2
        return 1
    fi

    local sel
    if [[ ${#lines[@]} -eq 1 ]]; then
        sel="${lines[0]}"
    else
        sel=$(printf '%s\n' "${lines[@]}" | fzf --ansi --tac --prompt='Select VPN > ' --height=~40%) || return 1
    fi
    basename "${sel%% ŌåÆ*}"
}

ns_start() {
    local ns="$1" config="$2" inet_iface i vpn_ip

    if [[ ! -f "$config" ]]; then
        echo "[!] Archivo VPN no encontrado: $config" >&2
        return 1
    fi

    inet_iface=$(get_iface) || {
        echo "[!] No se pudo detectar interfaz principal" >&2
        return 1
    }
    echo "[+] Interfaz principal: $inet_iface" >&2

    if ns_is_running "$ns"; then
        ns_cleanup "$ns"
    fi

    local vh vn hi ni gw subnet
    vh=$(ns_veth_host "$ns")
    vn=$(ns_veth_ns "$ns")
    hi=$(ns_host_ip "$ns")
    ni=$(ns_ns_ip "$ns")
    gw=$(ns_gateway "$ns")
    subnet=$(ns_subnet_cidr "$ns")

    echo "[+] Creando namespace..." >&2
    sudo ip netns add "$ns" || return 1
    sudo ip netns exec "$ns" ip link set lo up || return 1

    echo "[+] Creando veth pair..." >&2
    sudo ip link add "$vh" type veth peer name "$vn" || return 1
    sudo ip link set "$vn" netns "$ns" || return 1

    echo "[+] Configurando host..." >&2
    sudo ip addr add "$hi" dev "$vh" || return 1
    sudo ip link set "$vh" up || return 1

    echo "[+] Configurando namespace..." >&2
    sudo ip netns exec "$ns" ip addr add "$ni" dev "$vn" || return 1
    sudo ip netns exec "$ns" ip link set "$vn" up || return 1
    sudo ip netns exec "$ns" ip route add default via "$gw" || return 1

    echo "[+] Configurando DNS..." >&2
    sudo mkdir -p "/etc/netns/$ns" || return 1
    echo "nameserver $DNS_SERVER" | sudo tee "/etc/netns/$ns/resolv.conf" >/dev/null || return 1

    echo "[+] Activando forwarding..." >&2
    sudo sysctl -w net.ipv4.ip_forward=1 >/dev/null || return 1

    echo "[+] Configurando NAT..." >&2
    sudo iptables -t nat -C POSTROUTING -s "$subnet" -o "$inet_iface" -j MASQUERADE 2>/dev/null || \
    sudo iptables -t nat -A POSTROUTING -s "$subnet" -o "$inet_iface" -j MASQUERADE || return 1

    echo "[+] Verificando conectividad..." >&2
    sudo ip netns exec "$ns" ping -c 1 1.1.1.1 >/dev/null 2>&1 || true

    if has_socat; then
        echo "[+] Iniciando ADB forwarders..." >&2
        sudo socat TCP-LISTEN:5037,bind="$gw",fork,reuseaddr TCP:127.0.0.1:5037 >/dev/null 2>&1 &
        echo $! | sudo tee "$(ns_socat_host_pid "$ns")" >/dev/null
        sudo ip netns exec "$ns" socat TCP-LISTEN:5037,bind=127.0.0.1,fork,reuseaddr TCP:"$gw":5037 >/dev/null 2>&1 &
        echo $! | sudo tee "$(ns_socat_ns_pid "$ns")" >/dev/null
    fi

    echo "[+] Iniciando OpenVPN..." >&2
    sudo ip netns exec "$ns" openvpn \
        --config "$config" \
        --daemon \
        --resolv-retry infinite \
        --log "$(ns_log_file "$ns")" \
        --writepid "$(ns_pid_file "$ns")" >/dev/null 2>&1 || true

    echo "[+] Esperando tun0 (timeout ${VPN_TIMEOUT}s)..." >&2
    for ((i=0; i<VPN_TIMEOUT; i++)); do
        if ns_vpn_connected "$ns"; then
            break
        fi
        sleep 1
    done

    if ! ns_vpn_connected "$ns"; then
        echo "[!] VPN no conect├│" >&2
        echo >&2
        sudo cat "$(ns_log_file "$ns")" >&2 || true
        ns_cleanup "$ns"
        return 1
    fi

    vpn_ip=$(sudo ip netns exec "$ns" curl -s --max-time 5 ifconfig.me 2>/dev/null || echo "")
    if [[ ! "$vpn_ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        vpn_ip="offline"
    fi

    save_space "$ns" "$(basename "$config")" "$vpn_ip" "$(ns_alloc_subnet "$ns")"

    echo >&2
    echo "==================================" >&2
    echo " Namespace : $ns" >&2
    echo " VPN IP    : $vpn_ip" >&2
    echo "==================================" >&2
    echo >&2
}

create_new_vpn() {
    local ovpn ovpn_path ns_name
    echo >&2
    echo "ŌöüŌöüŌöü Crear Nueva VPN ŌöüŌöüŌöü" >&2
    echo >&2

    ovpn=$(select_ovpn) || {
        echo "[!] No se seleccion├│ ninguna VPN" >&2
        return 1
    }

    ovpn_path=$(find_config "$ovpn") || true
    if [[ -z "$ovpn_path" ]]; then
        ovpn_path="$ovpn"
    fi
    echo "[+] VPN seleccionada: $(basename "$ovpn_path")" >&2

    ns_name=$(auto_name "$(basename "$ovpn_path")")
    echo "[+] Creando espacio: $ns_name" >&2

    ns_start "$ns_name" "$ovpn_path"
}

