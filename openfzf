    mkdir -p "$CACHE_DIR"
    sqlite3 "$OPENED_DB" "CREATE TABLE IF NOT EXISTS opened (id TEXT PRIMARY KEY, last_opened INTEGER);" 2>/dev/null || true
    printf "  ${GREEN}[Ō£ō]${NC} %-12s %s\n" "cache" "$CACHE_DIR"
    printf "  ${GREEN}[Ō£ō]${NC} %-12s %s\n" "opened.db" "$OPENED_DB"

    echo

    # VPN config check (optional)
